<configuration>

    <appender name="CONSOLE"
              class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} [%level] %logger{36} - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- Уровень логов Hibernate - только ошибки -->
    <logger name="org.hibernate" level="ERROR"/>

    <!-- Уровень логов нашего приложения - всё -->
    <logger name="org.example" level="INFO"/>

    <root level="ERROR">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>